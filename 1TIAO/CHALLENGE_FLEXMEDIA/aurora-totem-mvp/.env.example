# Aurora Totem MVP Environment Variables Template
# Copy this to .env and modify as needed

# Database Configuration
DB_HOST=oracle.fiap.com.br
DB_PORT=1521
DB_SID=ORCL
DB_USERNAME=YOUR_RM_NUMBER
DB_PASSWORD=YOUR_PASSWORD

# API Configuration
API_HOST=localhost
API_PORT=8000
API_DEBUG=True

# Device Configuration  
DEVICE_ID=totem_aurora_001

# Simulation Configuration
SIM_INTERVAL_MIN=1.0
SIM_INTERVAL_MAX=5.0

# Dashboard Configuration
DASHBOARD_REFRESH=30
DASHBOARD_HOURS=1
MAX_RECORDS=100

# ML Configuration
MODEL_PATH=aurora_totem_model
SYNTHETIC_DATA_SIZE=1000
TEST_SIZE=0.2
RANDOM_STATE=42
CV_FOLDS=5
N_CLUSTERS=4
RETRAIN_INTERVAL=24

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FILE=aurora_totem.log