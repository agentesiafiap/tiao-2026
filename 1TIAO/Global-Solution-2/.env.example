# HeliOS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env com credenciais reais.

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=helios-solar-data

# ─── NASA ──────────────────────────────────────────────────────────────────────
# Obtenha uma chave gratuita em: https://api.nasa.gov/
# Use DEMO_KEY para testes (limite de 30 req/hora)
NASA_API_KEY=DEMO_KEY

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Necessário para geração de boletins em linguagem natural (Fase 8)
OPENAI_API_KEY=

# ─── MQTT / IoT Core ───────────────────────────────────────────────────────────
MQTT_BROKER_ENDPOINT=
MQTT_TOPIC=helios/magnetometer
MQTT_PORT=8883

# ─── Banco de Dados ────────────────────────────────────────────────────────────
RDS_HOST=
RDS_PORT=5432
RDS_DB_NAME=helios
RDS_USER=
RDS_PASSWORD=
DYNAMODB_TABLE_NAME=helios_kp_realtime

# ─── Alertas ───────────────────────────────────────────────────────────────────
SNS_TOPIC_ARN=
KP_ALERT_THRESHOLD=5

# ─── Ingestão ──────────────────────────────────────────────────────────────────
# Período de coleta histórica DONKI (ISO 8601)
DONKI_START_DATE=2024-01-01
DONKI_END_DATE=2024-12-31
